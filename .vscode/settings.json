{
	"editor.formatOnSave": false,
	"editor.defaultFormatter": null,
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"editor.codeActionsOnSave": {
		"quickfix.biome": "explicit"
	},
	"typescript.tsdk": "node_modules/typescript/lib",
	"typescript.enablePromptUseWorkspaceTsdk": true,

	// Project vocabulary for the cSpell editor extension — QEMU, RouterOS, and
	// tikoci domain terms absent from the default dictionary. cSpell matches
	// case-insensitively, so the lowercase form covers all casings (e.g.
	// "respawn" → "Respawning"). Keep sorted; add a word rather than tolerate noise.
	"cSpell.words": [
		"backoff",
		"biome",
		"borderless",
		"bunx",
		"centrs",
		"chardev",
		"cpuid",
		"delvm",
		"donny",
		"downscript",
		"failable",
		"funcs",
		"hostfwd",
		"hvf",
		"ifname",
		"initialise",
		"ipxe",
		"loadvm",
		"localappdata",
		"mactelnet",
		"markdownlint",
		"mcast",
		"mikropkl",
		"mikrotik",
		"mmio",
		"mndp",
		"netdev",
		"netinstall",
		"osinfo",
		"overfit",
		"pflash",
		"pgrep",
		"pipefail",
		"prereq",
		"qcow",
		"qemu",
		"quickchr",
		"respawn",
		"restraml",
		"reuseaddr",
		"romfile",
		"rosetta",
		"routeros",
		"savevm",
		"seabios",
		"slirp",
		"snmp",
		"sshpass",
		"tikbook",
		"tikoci",
		"tshark",
		"udevadm",
		"uefi",
		"unref",
		"userprofile",
		"virt",
		"virtio",
		"virtserialport",
		"vmnet",
		"whpx",
		"winbox",
		"winget",
		"winsock",
		"wrappable"
	]
}
